<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RandomCssMaui.Views.ClassesPage"
             Title="Lista klas">
    <StackLayout Padding="12" Spacing="8">
        <Label Text="Wybierz klasę" FontAttributes="Bold" FontSize="Medium" />
        <CollectionView ItemsSource="{Binding Classes}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame class="header">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>