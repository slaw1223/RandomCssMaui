<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RandomCssMaui.Views.AddPage"
             Title="Dodaj klasę i ucznia">
    <ScrollView>
        <VerticalStackLayout class="page-stack">
            <Label Text="Nowa klasa" class="header" />
            <Entry Text="{Binding NewClassName}" Placeholder="Nazwa klasy" />

            <Button Text="Dodaj klasę" Command="{Binding AddClassCommand}" />

            <Label Text="Dodaj ucznia do zaznaczonej klasy" class="header" />
            <Entry Text="{Binding NewStudentName}" Placeholder="Imię ucznia" />

            <HorizontalStackLayout class="actions">
                <Button Text="Dodaj ucznia" Command="{Binding AddStudentCommand}" />
                <Button Text="Zapisz do pliku" Command="{Binding SaveCommand}" />
            </HorizontalStackLayout>

            <Label Text="Wybierz klasę (select) żeby dodać ucznia" class="header" />
            <Picker ItemsSource="{Binding Classes}"
                ItemDisplayBinding="{Binding Name}"
                SelectedItem="{Binding SelectedClass}" />

            <Label Text="Klasy i uczniowie" class="header" />
            <CollectionView ItemsSource="{Binding Classes}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame class="card">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" class="header" />
                                <CollectionView ItemsSource="{Binding Students}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Label Text="{Binding Name}" class="small" />
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>