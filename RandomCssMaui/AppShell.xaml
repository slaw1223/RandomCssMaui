<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RandomCssMaui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RandomCssMaui"
    xmlns:views="clr-namespace:RandomCssMaui.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="RandomCssMaui"
    StyleClass="appShell">

    <TabBar>
        <ShellContent
            Title="Dodaj ucznia"
            ContentTemplate="{DataTemplate views:AddPage}"
            />
        <ShellContent
            Title="Edytuj klasy"
            ContentTemplate="{DataTemplate views:EditClassPage}"
            />
        <ShellContent
            Title="Losuj ucznia"
            ContentTemplate="{DataTemplate views:ClassesPage}"
            />
    </TabBar>
</Shell>
